{
    "name": "create-rasti",
    "version": "0.0.1",
    "description": "Create Rasti projects with Vite",
    "type": "module",
    "bin": {
        "create-rasti": "./bin/create-rasti.js"
    },
    "files": [
        "bin",
        "src",
        "templates",
        "extras",
        "!extras/**/node_modules"
    ],
    "scripts": {
