            <a class="\${classes.logoLink}" href="https://rasti.js.org" target="_blank"><img class="\${classes.logoLight}" src="https://cdn.jsdelivr.net/gh/8tentaculos/rasti@v4.0.1/docs/logo.svg" alt="test-app" /><img class="\${classes.logoDark}" src="https://cdn.jsdelivr.net/gh/8tentaculos/rasti@v4.0.1/docs/logo-dark.svg" alt="test-app" /></a>
