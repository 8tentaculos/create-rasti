        if (!c) continue;

        const t = typeof c;

        if (t === 'string' || t === 'number') out = add(out, c);
        else if (Array.isArray(c)) out = add(out, parse(c));
        else if (t === 'object') for (const key in c) c[key] && (out = add(out, key));
