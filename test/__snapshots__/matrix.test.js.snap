                count is \${({ props }) => props.count}
            </\${Button}>
        </div>
        <div class="info">
            <div class="info-stack">
                <p class="info-description">Pre-rendered static site with <a href="https://rasti.js.org" target="_blank">Rasti</a> + <a href="https://vite.dev" target="_blank">Vite</a> + <a href="https://expressjs.com" target="_blank">Express</a>. Development uses SSR; run <code>npm run build:static</code> to export configured URLs to static HTML under <code>dist/static</code>.</p>
                <div class="info-includes"><p>Router: <a href="https://github.com/8tentaculos/create-rasti/tree/master/extras/micro-router" target="_blank" rel="noopener">micro-router</a></p></div>
                <p class="info-hint">Edit <code>src/App.js</code> and save to test HMR.</p>
            </div>
        </div>
    </div>
\`;

export default Home;
